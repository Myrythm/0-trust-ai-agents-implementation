# ZTA service environment template.
# Copy to .env and fill in real values. Never commit .env.

# --- General ---
ZTA_ENV=dev
ZTA_LOG_LEVEL=INFO

# --- LangChain / OpenAI (used by F8+) ---
ZTA_OPENAI_API_KEY=
ZTA_OPENAI_MODEL=gpt-4o-mini

# --- Policy + audit (used by F6+) ---
ZTA_POLICY_PATH=./policy.yaml
ZTA_AUDIT_PATH=./audit.jsonl

# --- Identity (used by F2+) ---
ZTA_KEY_DIR=./.zta/keys

# --- Demo data (used by F12+) ---
ZTA_DB_PATH=./data.db

# --- Auth & RBAC ---
# Secret used to sign session cookies. Set a long random string in any real
# deployment; if unset, the app uses an ephemeral key (sessions reset on restart).
ZTA_SECRET_KEY=change-me-to-a-long-random-string
# RBAC role matrix (who can use which pages/tools/tables).
ZTA_ROLES_PATH=./roles.yaml
